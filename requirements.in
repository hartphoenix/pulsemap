# Direct Python dependencies for the audio-analysis pipeline (src/bootstrap/).
#
# This file lists only the packages the scripts import directly. The full,
# fully-pinned dependency tree (including transitive deps) lives in
# requirements.txt — install from THAT for a reproducible environment:
#
#     ./.venv/bin/pip install -r requirements.txt
#
# Edit this file when adding/removing a direct dependency, then refresh the
# lock:  ./.venv/bin/pip freeze > requirements.txt
#
# Requires Python 3.11 (see .python-version). Many of these ship platform- and
# Python-version-specific wheels (torch, torchaudio, essentia), so the lock is
# only guaranteed reproducible on the same platform + Python minor version.

# --- core audio / numerics ---
numpy==2.4.4
scipy==1.17.1
librosa==0.11.0
soundfile==0.13.1

# --- source separation ---
demucs==4.0.1
audio-separator==0.44.1

# --- transcription / pitch / beats ---
whisperx==3.8.5
basic-pitch==0.4.0
torchcrepe==0.0.24
beat-this==1.1.0

# --- chord recognition ---
lv-chordia==1.0.0
pychord==1.3.2
essentia==2.1b6.dev1389

# --- MIDI ---
pretty-midi==0.2.11

# --- deep learning runtime (imported directly; also pulled by the above) ---
torch==2.8.0
torchaudio==2.8.0
