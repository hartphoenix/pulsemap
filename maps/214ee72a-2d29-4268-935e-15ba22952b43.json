  "lyrics": [
    {
      "t": 2335,
      "text": "Come up to meet you, tell you I’m sorry You don’t know how lovely you are",
      "end": 15040
    },
    {
      "t": 15040,
      "text": "I had to find you Tell you I need you&nbsp;",
      "end": 22912
    },
    {
      "t": 22912,
      "text": "Tell you I set you apart",
      "end": 28160
    },
    {
      "t": 28160,
      "text": "Tell me your secrets And ask me your questions&nbsp;",
      "end": 34560
    },
    {
      "t": 34560,
      "text": "Oh, let’s go back to the start",
      "end": 38320
    },
    {
      "t": 41200,
      "text": "Running in circles&nbsp;",
      "end": 43840
    },
    {
      "t": 44560,
      "text": "Coming up tails Heads on a science apart",
      "end": 51520
    },
    {
      "t": 53920,
      "text": "Nobody said it was easy It’s such a shame for us to part&nbsp;",
      "end": 67040
    },
    {
      "t": 67040,
      "text": "Nobody said it was easy No one ever said it would be this hard",
      "end": 82560
    },
    {
      "t": 82560,
      "text": "Oh, take me back to the start",
      "end": 87840
    },
    {
      "t": 100680,
      "text": "I was just guessing At numbers and figures&nbsp;",
      "end": 106440
    },
    {
      "t": 102936,
      "text": "Pulling the puzzles apart",
      "end": 113360
    },
    {
      "t": 113360,
      "text": "Questions of science&nbsp;",
      "end": 115840
    },
    {
      "t": 116560,
      "text": "Science and progress Do not speak as loud as my heart",
      "end": 126120
    },
    {
      "t": 126560,
      "text": "Tell me you love me Come back and haunt me&nbsp;",
      "end": 133040
    },
    {
      "t": 133320,
      "text": "Oh, and I rush to the start",
      "end": 139470
    },
    {
      "t": 139470,
      "text": "Running&nbsp;in circles&nbsp;Chasing our tails",
      "end": 145920
    },
    {
      "t": 146400,
      "text": "Coming back as we are",
      "end": 151840
    },
    {
      "t": 152160,
      "text": "Nobody said it was easy Oh, it’s such a shame for us to part&nbsp;",
      "end": 165360
    },
    {
      "t": 165360,
      "text": "Nobody said it was easy No one ever said it would be so hard",
      "end": 180960
    },
    {
      "t": 180960,
      "text": "I’m going back to the start",
