  "lyrics": [
    {
      "t": 11600,
      "text": "Another turning point, a fork stuck in the road",
      "end": 16040
    },
    {
      "t": 16620,
      "text": "Time grabs you by the wrist, directs you where to go",
      "end": 21000
    },
    {
      "t": 21640,
      "text": "So make the best of this test and don't ask why",
      "end": 26300
    },
    {
      "t": 26680,
      "text": "It's not a question, but a lesson learned in time",
      "end": 31080
    },
    {
      "t": 31080,
      "text": "It's something unpredictable, but in the end it's right",
      "end": 35840
    },
    {
      "t": 36120,
      "text": "I hope you had the time of your life",
      "end": 40440
    },
    {
      "t": 49100,
      "text": "So take the photographs and still frames in your mind",
      "end": 53820
    },
    {
      "t": 54400,
      "text": "Hang it on a shelf in good health and good time",
      "end": 58780
