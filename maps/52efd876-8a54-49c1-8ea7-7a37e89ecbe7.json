  "lyrics": [
    {
      "t": 8790,
      "text": "Jolene, Jolene, Jolene, Jolene",
      "end": 13490
    },
    {
      "t": 13490,
      "text": "I'm begging of you, please, don't take my man",
      "end": 19490
    },
    {
      "t": 19490,
      "text": "Jolene, Jolene, Jolene, Jolene",
      "end": 25960
    },
    {
      "t": 25960,
      "text": "Please don't take him just because you can",
      "end": 32860
    },
    {
      "t": 32860,
      "text": "Your beauty is beyond compare",
      "end": 34730
    },
    {
      "t": 34730,
      "text": "With flaming locks of auburn hair",
      "end": 36940
    },
    {
      "t": 36940,
      "text": "With ivory skin, and eyes of emerald green",
      "end": 42240
    },
    {
      "t": 42240,
      "text": "Your smile is like a breath of spring",
      "end": 45420
    },
    {
      "t": 45420,
      "text": "Your voice is soft like summer rain",
      "end": 48070
    },
    {
      "t": 48070,
      "text": "And I cannot compete with you, Jolene",
      "end": 53880
    },
    {
      "t": 53880,
      "text": "He talks about you in his sleep",
      "end": 56500
    },
    {
      "t": 56500,
      "text": "And there's nothing I can do to keep",
      "end": 58840
    },
    {
      "t": 58840,
      "text": "From crying when he calls your name, Jolene",
      "end": 63600
    },
    {
      "t": 63600,
      "text": "And I can easily understand",
      "end": 67480
    },
    {
      "t": 67480,
      "text": "How you could easily take my man",
      "end": 69560
    },
    {
      "t": 69560,
      "text": "But you don't know what he means to me, Jolene",
      "end": 75670
    },
    {
      "t": 75670,
      "text": "Jolene, Jolene, Jolene, Jolene",
      "end": 81370
    },
    {
      "t": 81370,
      "text": "I'm begging of you, please, don't take my man",
      "end": 87230
    },
    {
      "t": 87230,
      "text": "Jolene, Jolene, Jolene, Jolene",
      "end": 93100
    },
    {
      "t": 93100,
      "text": "Please don't take him just because you can",
      "end": 100230
    },
    {
      "t": 100230,
      "text": "You could have your choice of men",
      "end": 102300
    },
    {
      "t": 102300,
      "text": "But I could never love again",
      "end": 104420
    },
    {
      "t": 104420,
      "text": "He's the only one for me, Jolene",
      "end": 110030
    },
    {
      "t": 110030,
      "text": "I had to have this talk with you",
      "end": 113140
    },
    {
      "t": 113140,
      "text": "My happiness depends on you",
      "end": 115340
    },
    {
      "t": 115340,
      "text": "And whatever you decide to do, Jolene",
      "end": 121210
    },
    {
      "t": 121210,
      "text": "Jolene, Jolene, Jolene, Jolene",
      "end": 127160
    },
    {
      "t": 127160,
      "text": "I'm begging of you, please, don't take my man",
      "end": 133190
    },
    {
      "t": 133190,
